/* pages/admin/statistics.wxss */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.overview-section {
  background-color: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.overview-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.overview-grid {
  display: flex;
  flex-wrap: wrap;
}

.overview-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.overview-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #007aff;
  margin-bottom: 8rpx;
}

.overview-label {
  font-size: 24rpx;
  color: #666;
}

.chart-section {
  background-color: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.time-tabs {
  display: flex;
  gap: 16rpx;
}

.time-tab {
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  color: #666;
  background-color: #f5f5f5;
  border-radius: 16rpx;
}

.time-tab.active {
  color: white;
  background-color: #007aff;
}

.chart-container {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 300rpx;
  padding: 20rpx 0;
}

.chart-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 60rpx;
}

.bar-wrapper {
  width: 40rpx;
  height: 240rpx;
  background-color: #f5f5f5;
  border-radius: 4rpx;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}

.bar-value {
  width: 100%;
  background-color: #007aff;
  border-radius: 4rpx 4rpx 0 0;
  min-height: 8rpx;
  transition: height 0.3s ease;
}

.bar-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 12rpx;
}

.hot-section {
  background-color: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.hot-list {
  display: flex;
  flex-direction: column;
}

.hot-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.hot-item:last-child {
  border-bottom: none;
}

.hot-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  color: white;
  margin-right: 16rpx;
  background-color: #999;
}

.rank-1 {
  background-color: #ffd700;
}

.rank-2 {
  background-color: #c0c0c0;
}

.rank-3 {
  background-color: #cd7f32;
}

.hot-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.hot-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.hot-stats {
  display: flex;
  gap: 16rpx;
}

.hot-stat {
  font-size: 24rpx;
  color: #999;
}

.hot-trend {
  font-size: 32rpx;
  font-weight: bold;
}

.trend-up {
  color: #52c41a;
}

.trend-down {
  color: #ff4d4f;
}

.activity-section {
  background-color: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.activity-grid {
  display: flex;
}

.activity-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.activity-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #007aff;
  margin-bottom: 8rpx;
}

.activity-label {
  font-size: 24rpx;
  color: #666;
}

.category-section {
  background-color: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.category-list {
  display: flex;
  flex-direction: column;
}

.category-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.category-info {
  width: 180rpx;
  display: flex;
  flex-direction: column;
}

.category-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.category-count {
  font-size: 22rpx;
  color: #999;
}

.category-bar {
  flex: 1;
  height: 16rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.category-progress {
  height: 100%;
  background-color: #007aff;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.category-percent {
  width: 80rpx;
  text-align: right;
  font-size: 26rpx;
  color: #666;
}
