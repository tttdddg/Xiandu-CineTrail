/* pages/spot-list/spot-list.wxss */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.search-bar {
  padding: 20rpx;
  background-color: white;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-input {
  width: 100%;
  height: 64rpx;
  padding: 0 24rpx;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.category-scroll {
  background-color: white;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-list {
  display: flex;
  padding: 20rpx;
  white-space: nowrap;
}

.category-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  font-size: 28rpx;
  color: #666;
  background-color: #f5f5f5;
  border-radius: 24rpx;
}

.category-item.active {
  color: white;
  background-color: #007aff;
}

.sort-bar {
  display: flex;
  padding: 20rpx;
  background-color: white;
  border-bottom: 1rpx solid #f0f0f0;
}

.sort-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  padding: 12rpx 0;
}

.sort-item.active {
  color: #007aff;
  font-weight: bold;
}

.spot-list {
  flex: 1;
  padding: 20rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 100rpx 0;
}

.spot-item {
  display: flex;
  background-color: white;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.spot-cover {
  width: 200rpx;
  height: 200rpx;
  object-fit: cover;
}

.spot-info {
  flex: 1;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
}

.spot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.spot-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.hot-badge {
  display: flex;
  align-items: center;
  padding: 4rpx 12rpx;
  background-color: #fff3e0;
  border-radius: 12rpx;
}

.hot-icon {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.hot-value {
  font-size: 24rpx;
  color: #ff9800;
  font-weight: bold;
}

.spot-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: #666;
  background-color: #f0f0f0;
  border-radius: 12rpx;
}

.tag-movie {
  color: #ff5722;
  background-color: #ffebee;
}

.tag-game {
  color: #2196f3;
  background-color: #e3f2fd;
}

.tag-culture {
  color: #9c27b0;
  background-color: #f3e5f5;
}

.tag-nature {
  color: #4caf50;
  background-color: #e8f5e9;
}

.spot-stats {
  display: flex;
  margin-bottom: 12rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #999;
  margin-right: 20rpx;
}

.spot-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
