/* pages/detail/detail.wxss */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.cover-image {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
}

.spot-info {
  padding: 24rpx;
  background-color: white;
  margin-bottom: 16rpx;
}

.spot-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.spot-type {
  margin-bottom: 24rpx;
}

.type-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background-color: #e6f7ff;
  color: #007aff;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.spot-description {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.checkin-section {
  padding: 24rpx;
  background-color: white;
  margin-top: auto;
}

.checkin-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 32rpx;
  background-color: #07c160;
  color: white;
  border-radius: 40rpx;
}

.checkin-btn.btn-disabled {
  background-color: #ccc;
}
