/* pages/detail/detail.wxss */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.cover-image {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
}

.spot-info {
  padding: 24rpx;
  background-color: white;
  margin-bottom: 16rpx;
}

.spot-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.spot-type {
  margin-bottom: 24rpx;
}

.type-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background-color: #e6f7ff;
  color: #007aff;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.spot-description {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.checkin-stats {
  display: flex;
  background-color: white;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #007aff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

.distance-tip {
  padding: 16rpx 24rpx;
  background-color: white;
  margin-bottom: 16rpx;
}

.distance-text {
  font-size: 28rpx;
  color: #52c41a;
}

.distance-text.warning {
  color: #ff9800;
}

.photo-section {
  background-color: white;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.photo-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.photo-preview {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  object-fit: cover;
}

.photo-delete {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: #ff4d4f;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
}

.photo-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ddd;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 60rpx;
  color: #999;
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.photo-actions {
  display: flex;
  gap: 16rpx;
}

.photo-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  background-color: #f5f5f5;
  color: #333;
  border-radius: 8rpx;
}

.review-status {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.review-label {
  font-size: 28rpx;
  color: #666;
}

.review-value {
  font-size: 28rpx;
  font-weight: bold;
}

.status-pending {
  color: #ff9800;
}

.status-approved {
  color: #52c41a;
}

.status-rejected {
  color: #ff4d4f;
}

.checkin-section {
  padding: 24rpx;
  background-color: white;
  margin-top: auto;
}

.checkin-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 32rpx;
  background-color: #07c160;
  color: white;
  border-radius: 40rpx;
  margin-bottom: 16rpx;
}

.checkin-btn.btn-disabled {
  background-color: #ccc;
}

.makeup-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 32rpx;
  background-color: #ff9800;
  color: white;
  border-radius: 40rpx;
}

.photo-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-photo {
  width: 100%;
  height: 100%;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 90%;
  max-height: 80vh;
  background-color: white;
  border-radius: 12rpx;
  z-index: 1001;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  padding: 16rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.modal-footer {
  display: flex;
  padding: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 32rpx;
  border-radius: 8rpx;
  margin: 0 8rpx;
}

.cancel-btn {
  background-color: #f5f5f5;
  color: #666;
}

.confirm-btn {
  background-color: #007aff;
  color: white;
}
