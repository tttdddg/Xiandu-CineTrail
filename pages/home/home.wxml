<!-- pages/home/home.wxml -->
<view class="container">
  <!-- 地图组件 -->
  <map 
    id="map"
    style="width: 100%; height: 100vh;"
    latitude="{{latitude}}"
    longitude="{{longitude}}"
    scale="{{scale}}"
    show-location="{{showLocation}}"
    markers="{{markers}}"
    polyline="{{polyline}}"
    bindmarkertap="onMarkerTap"
    bindregionchange="onRegionChange"
  ></map>
  
  <!-- 地图控制按钮 -->
  <view class="map-controls">
    <view class="control-btn" bindtap="moveToLocation">
      <text class="control-icon">📍</text>
    </view>
    <view class="control-btn" bindtap="showNearbyPanel">
      <text class="control-icon">🔍</text>
    </view>
  </view>
  
  <!-- Marker 点击弹出层 -->
  <view class="marker-popup" wx:if="{{selectedMarker}}">
    <view class="popup-content">
      <view class="popup-header">
        <text class="popup-title">{{selectedMarker.name}}</text>
        <view class="hot-badge">
          <text class="hot-icon">🔥</text>
          <text class="hot-value">{{selectedMarker.hotScore}}</text>
        </view>
      </view>
      <text class="popup-desc">{{selectedMarker.desc}}</text>
      <view class="popup-stats">
        <text class="stat-item">✅ {{selectedMarker.checkinCount}}人打卡</text>
      </view>
      <view class="popup-actions">
        <button class="popup-btn route-btn" bindtap="planRoute">路线规划</button>
        <button class="popup-btn detail-btn" bindtap="goToDetail">查看详情</button>
      </view>
    </view>
  </view>
  
  <!-- 附近推荐面板 -->
  <view class="nearby-panel" wx:if="{{showNearbyPanel}}">
    <view class="panel-header">
      <text class="panel-title">附近推荐</text>
      <text class="panel-close" bindtap="hideNearbyPanel">×</text>
    </view>
    <view class="nearby-list">
      <view class="nearby-item" wx:for="{{nearbySpots}}" wx:key="id" bindtap="goToSpot" data-spot="{{item}}">
        <view class="nearby-info">
          <text class="nearby-name">{{item.name}}</text>
          <text class="nearby-distance">{{item.distanceText}}</text>
        </view>
        <view class="nearby-actions">
          <button class="nearby-btn" catchtap="planRoute" data-spot="{{item}}">导航</button>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 路线规划面板 -->
  <view class="route-panel" wx:if="{{showRoutePanel}}">
    <view class="panel-header">
      <text class="panel-title">路线规划</text>
      <text class="panel-close" bindtap="hideRoutePanel">×</text>
    </view>
    <view class="route-info">
      <view class="route-item">
        <text class="route-label">距离</text>
        <text class="route-value">{{distance}}米</text>
      </view>
      <view class="route-item">
        <text class="route-label">预计时间</text>
        <text class="route-value">{{duration}}分钟</text>
      </view>
    </view>
    <button class="route-nav-btn" bindtap="openNavigation">开始导航</button>
  </view>
</view>
