/* pages/home/home.wxss */
.container {
  position: relative;
  height: 100vh;
}

.map-controls {
  position: fixed;
  right: 20rpx;
  bottom: 200rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  z-index: 100;
}

.control-btn {
  width: 80rpx;
  height: 80rpx;
  background-color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.control-icon {
  font-size: 40rpx;
}

.marker-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: white;
  border-radius: 20rpx 20rpx 0 0;
  padding: 32rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 1000;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.popup-content {
  display: flex;
  flex-direction: column;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.popup-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.hot-badge {
  display: flex;
  align-items: center;
  padding: 4rpx 12rpx;
  background-color: #fff3e0;
  border-radius: 12rpx;
}

.hot-icon {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.hot-value {
  font-size: 24rpx;
  color: #ff9800;
  font-weight: bold;
}

.popup-desc {
  font-size: 28rpx;
  color: #666;
  text-align: left;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.popup-stats {
  display: flex;
  margin-bottom: 24rpx;
}

.stat-item {
  font-size: 26rpx;
  color: #999;
  margin-right: 20rpx;
}

.popup-actions {
  display: flex;
  gap: 16rpx;
}

.popup-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  border-radius: 36rpx;
}

.route-btn {
  background-color: #f5f5f5;
  color: #333;
}

.detail-btn {
  background-color: #007aff;
  color: white;
}

.nearby-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: white;
  border-radius: 20rpx 20rpx 0 0;
  max-height: 60vh;
  z-index: 1001;
  animation: slideUp 0.3s ease-out;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.panel-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.panel-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.nearby-list {
  padding: 20rpx;
  max-height: 50vh;
  overflow-y: auto;
}

.nearby-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.nearby-info {
  display: flex;
  flex-direction: column;
}

.nearby-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.nearby-distance {
  font-size: 24rpx;
  color: #999;
}

.nearby-btn {
  padding: 8rpx 24rpx;
  font-size: 26rpx;
  background-color: #007aff;
  color: white;
  border-radius: 24rpx;
}

.route-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: white;
  border-radius: 20rpx 20rpx 0 0;
  padding: 32rpx;
  z-index: 1001;
  animation: slideUp 0.3s ease-out;
}

.route-info {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.route-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.route-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.route-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.route-nav-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 32rpx;
  background-color: #07c160;
  color: white;
  border-radius: 40rpx;
}
