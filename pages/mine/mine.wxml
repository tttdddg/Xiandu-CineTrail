<!-- pages/mine/mine.wxml -->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-info">
    <image class="avatar" src="{{userInfo.avatarUrl || 'https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=default%20user%20avatar&image_size=square'}}"></image>
    <text class="nickname">{{userInfo.nickName || '未登录'}}</text>
  </view>
  
  <!-- 打卡统计 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-number">{{totalCheckins}}</text>
      <text class="stat-label">累计打卡</text>
    </view>
  </view>
  
  <!-- 打卡记录 -->
  <view class="checkin-list">
    <text class="list-title">打卡记录</text>
    <view wx:if="{{checkins.length === 0}}" class="empty-tip">
      暂无打卡记录
    </view>
    <view wx:else>
      <view class="checkin-item" wx:for="{{checkins}}" wx:key="index">
        <view class="item-info">
          <text class="spot-name">{{item.spotName}}</text>
          <text class="checkin-time">{{item.checkinTime}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 退出登录 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>