/* pages/mine/mine.wxss */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.user-card {
  background: linear-gradient(135deg, #007aff 0%, #00c6ff 100%);
  padding: 40rpx 32rpx;
  color: white;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.user-detail {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  display: block;
}

.level-badge {
  display: inline-flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
}

.level-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.level-text {
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 8rpx;
}

.level-name {
  font-size: 22rpx;
}

.growth-section {
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 20rpx;
}

.growth-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.growth-label {
  font-size: 24rpx;
}

.growth-value {
  font-size: 24rpx;
  font-weight: bold;
}

.growth-bar {
  height: 12rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.growth-progress {
  height: 100%;
  background-color: #ffd700;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.growth-tip {
  font-size: 22rpx;
  opacity: 0.8;
}

.badge-section {
  background-color: white;
  margin: 20rpx;
  padding: 24rpx;
  border-radius: 12rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #007aff;
}

.badge-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.badge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100rpx;
}

.badge-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 8rpx;
}

.badge-icon-text {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.badge-name {
  font-size: 22rpx;
  color: #333;
  text-align: center;
}

.badge-item.locked .badge-icon-text {
  opacity: 0.3;
}

.badge-item.locked .badge-name {
  color: #999;
}

.stats-card {
  background-color: white;
  margin: 0 20rpx 20rpx;
  padding: 24rpx;
  border-radius: 12rpx;
}

.stats-row {
  display: flex;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #007aff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

.chart-section {
  background-color: white;
  margin: 0 20rpx 20rpx;
  padding: 24rpx;
  border-radius: 12rpx;
}

.chart-container {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 200rpx;
  padding-top: 20rpx;
}

.chart-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 60rpx;
}

.bar-value {
  width: 40rpx;
  background-color: #007aff;
  border-radius: 4rpx 4rpx 0 0;
  min-height: 8rpx;
  transition: height 0.3s ease;
}

.bar-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

.menu-section {
  background-color: white;
  margin: 0 20rpx 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-badge {
  background-color: #ff4d4f;
  color: white;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
}

.menu-arrow {
  font-size: 28rpx;
  color: #999;
}

.logout-section {
  margin: 20rpx;
  padding-bottom: 40rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  background-color: #ff4d4f;
  color: white;
  border-radius: 44rpx;
}
