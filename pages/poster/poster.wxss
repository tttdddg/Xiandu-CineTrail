/* pages/poster/poster.wxss */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.poster-wrapper {
  width: 100%;
  background-color: white;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
}

.poster-preview {
  width: 100%;
  display: block;
}

.poster-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
  margin-bottom: 24rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  background-color: white;
  color: #333;
  border-radius: 44rpx;
  border: 2rpx solid #ddd;
}

.action-btn.primary {
  background-color: #007aff;
  color: white;
  border: none;
}

.poster-tips {
  text-align: center;
}

.tip-text {
  font-size: 26rpx;
  color: #999;
}
